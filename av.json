# 移除 remark 字段的函数
def remove_remarks(data):
    if isinstance(data, dict):
        if 'remark' in data:
            del data['remark']
        for key, value in data.items():
            remove_remarks(value)
    elif isinstance(data, list):
        for item in data:
            remove_remarks(item)

# 调用函数移除 remark
