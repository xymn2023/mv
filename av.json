# 将处理后的JSON转换为紧凑的字符串，并进行Base64编码
json_string_compact = json.dumps(fixed_json_data, separators=(',', ':'), ensure_ascii=False) # 确保中文不被转义

encoded_bytes = base64.b64encode(json_string_compact.encode('utf-8'))
encoded_string = encoded_bytes.decode('utf-8')

print("\n--- 移除remark并Base64编码后的字符串 ---")
print(encoded_string)

# 验证一下解码
decoded_bytes = base64.b64decode(encoded_string)
decoded_string = decoded_bytes.decode('utf-8')
decoded_json = json.loads(decoded_string)
